{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "evidence-chain",
  "version": "0.1.0",
  "identifier": "com.secxun.evidencechain",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5178",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["evidence", "evc"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "登录",
        "width": 720,
        "height": 420,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "center": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
